############################################################
## ПРОДУКТ И ПЛАТФОРМА (ОБЯЗАТЕЛЬНО!)
############################################################

# Вендор - Xiaomi
CONFIG_VENDOR=XIAOMI
# Продукт - MT7628 (чипсет R4AC)
CONFIG_PRODUCT=MT7628
# ID продукта (макс 23 символа). v2 - для новых ревизий R4AC
CONFIG_FIRMWARE_PRODUCT_ID="MI-4A_100M_v2"


############################################################
## ЯДРО LINUX (КРИТИЧНЫЕ НАСТРОЙКИ)
############################################################

# Режим сна процессора (downclock до 100MHz в простое)
# ВКЛЮЧИТЬ - экономит электроэнергию и меньше греется
CONFIG_FIRMWARE_CPU_SLEEP=y

# Драйвер WiFi 5GHz (MT7612E). 4.1 - актуальная версия
CONFIG_FIRMWARE_WIFI5_DRIVER=4.1

# Драйвер WiFi 2.4GHz (MT7628). 4.0 - стабильная версия
CONFIG_FIRMWARE_WIFI2_DRIVER=4.0

# IPv6 - ОТКЛЮЧИТЬ для экономии RAM (64MB критично)
# На 64MB RAM IPv6 съедает ~5-8MB памяти
CONFIG_FIRMWARE_ENABLE_IPV6=n

# USB - ОТКЛЮЧИТЬ (у R4AC нет USB порта)
CONFIG_FIRMWARE_ENABLE_USB=n

# Файловые системы - все ОТКЛЮЧИТЬ (нет USB → не нужны)
# FAT/FAT32
CONFIG_FIRMWARE_ENABLE_FAT=n
# exFAT
CONFIG_FIRMWARE_ENABLE_EXFAT=n
# EXT2
CONFIG_FIRMWARE_ENABLE_EXT2=n
# EXT3
CONFIG_FIRMWARE_ENABLE_EXT3=n
# EXT4
CONFIG_FIRMWARE_ENABLE_EXT4=n
# FUSE (файловые системы userspace)
CONFIG_FIRMWARE_ENABLE_FUSE=n
# SWAP - ВКЛЮЧИТЬ! Критично для 64MB RAM (zram будет использовать)
CONFIG_FIRMWARE_ENABLE_SWAP=y

# Камеры USB (UVC) - не нужно (нет USB)
CONFIG_FIRMWARE_INCLUDE_UVC=n
# HID (клавиатуры/мыши) - не нужно
CONFIG_FIRMWARE_INCLUDE_HID=n
# USB-Serial - не нужно
CONFIG_FIRMWARE_INCLUDE_SERIAL=n
# USB-Audio - не нужно
CONFIG_FIRMWARE_INCLUDE_AUDIO=n


############################################################
## СЕТЕВЫЕ МОДУЛИ ЯДРА
############################################################

# IPSet (для firewall, vpn, zapret) - ВКЛЮЧИТЬ
CONFIG_FIRMWARE_INCLUDE_IPSET=y

# NFS - ОТКЛЮЧИТЬ (тяжелый, не нужен на роутере)
CONFIG_FIRMWARE_INCLUDE_NFSD=n
CONFIG_FIRMWARE_INCLUDE_NFSC=n

# CIFS (SMB клиент) - можно включить для NAS
# Легкий, полезен если есть сетевое хранилище
CONFIG_FIRMWARE_INCLUDE_CIFS=y

# Shortcut Forwarding Engine (SFE) - ВКЛЮЧИТЬ!
# Аппаратное ускорение NAT, разгружает CPU
CONFIG_FIRMWARE_INCLUDE_SHORTCUT_FE=y

# XFRM (IPsec) - ОТКЛЮЧИТЬ (используем WireGuard вместо IPsec)
CONFIG_FIRMWARE_INCLUDE_XFRM=n

# QoS (качество обслуживания) - ОТКЛЮЧИТЬ
# На 64MB RAM лучше использовать аппаратный SFE
CONFIG_FIRMWARE_INCLUDE_QOS=n
CONFIG_FIRMWARE_INCLUDE_IMQ=n
CONFIG_FIRMWARE_INCLUDE_IFB=n


############################################################
## ЯЗЫК ИНТЕРФЕЙСА
############################################################

# Русский язык для веб-интерфейса
CONFIG_FIRMWARE_INCLUDE_LANG_RU=y

# Остальные языки - отключены для экономии места
# CONFIG_FIRMWARE_INCLUDE_LANG_BR=n
# CONFIG_FIRMWARE_INCLUDE_LANG_CN=n
# ... и т.д.


############################################################
## VPN (КРИТИЧНО ВАЖНО)
############################################################

# OpenVPN - ОТКЛЮЧИТЬ! Очень тяжелый (~1.6MB RAM + openssl)
# На 64MB RAM OpenVPN + Web интерфейс = подвисания
CONFIG_FIRMWARE_INCLUDE_OPENVPN=n

# WireGuard - ВКЛЮЧИТЬ! Легкий, быстрый, современный
# Использует ~200-300KB RAM против 1.5MB у OpenVPN
CONFIG_FIRMWARE_INCLUDE_WIREGUARD=y

# AmneziaWG (модификация WG для обхода блокировок) - опционально
# Если провайдер блокирует WG - включить, иначе не нужно
CONFIG_FIRMWARE_INCLUDE_AMNEZIAWG=n

# EoIP (туннели MikroTik) - ОТКЛЮЧИТЬ
CONFIG_FIRMWARE_INCLUDE_EOIP=n

# L2TP клиент - ОТКЛЮЧИТЬ (устаревший, небезопасный)
CONFIG_FIRMWARE_INCLUDE_RPL2TP=n


############################################################
## ОБХОД БЛОКИРОВОК (ZAPRET/NFQWS)
############################################################

# NFQWS - ВКЛЮЧИТЬ! Обход DPI (Deep Packet Inspection)
# Легкая версия zapret, работает на уровне ядра
# Потребление: ~100-200KB RAM (очень мало!)
CONFIG_FIRMWARE_INCLUDE_NFQWS=y

# Важно: полный zapret (с tpws и демонами) НЕ ВЛЕЗЕТ в 64MB
# Используем только nfqws (фильтрация пакетов)


############################################################
## SSH И БЕЗОПАСНОСТЬ
############################################################

# Dropbear - легкий SSH сервер (~0.3MB) - ВКЛЮЧИТЬ
CONFIG_FIRMWARE_INCLUDE_DROPBEAR=y
# Оптимизация шифрования dropbear (ускорение)
CONFIG_FIRMWARE_INCLUDE_DROPBEAR_FAST_CODE=y

# OpenSSH - ОТКЛЮЧИТЬ! Тяжелый (~1MB)
CONFIG_FIRMWARE_INCLUDE_OPENSSH=n

# SFTP - ОТКЛЮЧИТЬ! Требует OpenSSL (~1.2MB)
# Для передачи файлов используй SCP (встроен в dropbear)
CONFIG_FIRMWARE_INCLUDE_SFTP=n

# EAP-PEAP (для WiFi Enterprise) - ОТКЛЮЧИТЬ (требует OpenSSL)
CONFIG_FIRMWARE_INCLUDE_EAP_PEAP=n


############################################################
## SSL/HTTPS (ОПТИМИЗАЦИЯ)
############################################################

# OpenSSL - минимальная конфигурация

# Эллиптические кривые - ОТКЛЮЧИТЬ (экономия 0.1MB)
CONFIG_FIRMWARE_INCLUDE_OPENSSL_EC=n

# OpenSSL CLI (командная строка) - ОТКЛЮЧИТЬ (экономия 0.4MB)
# Не нужен для работы VPN
CONFIG_FIRMWARE_INCLUDE_OPENSSL_EXE=n

# HTTPS для админки - ОТКЛЮЧИТЬ (используем HTTP в локальной сети)
# Экономия 1.2MB RAM (OpenSSL)
CONFIG_FIRMWARE_INCLUDE_HTTPS=n

# HTTPS для DDNS - ОТКЛЮЧИТЬ (HTTP достаточно)
CONFIG_FIRMWARE_INCLUDE_DDNS_SSL=n

# Curl - ВКЛЮЧИТЬ (нужен для скриптов, обновлений)
CONFIG_FIRMWARE_INCLUDE_CURL=y
# QUIC в Curl - ОТКЛЮЧИТЬ (экономия 0.4MB)
CONFIG_FIRMWARE_INCLUDE_QUIC=n
CONFIG_FIRMWARE_INCLUDE_QUIC_NGTCP2=n


############################################################
## DNS (ВЫБРАТЬ ОДИН ЛЕГКИЙ)
############################################################

# DNSCrypt - ОТКЛЮЧИТЬ (тяжелый, 0.5MB)
CONFIG_FIRMWARE_INCLUDE_DNSCRYPT=n

# Stubby (DoT) - ОТКЛЮЧИТЬ (0.5MB)
CONFIG_FIRMWARE_INCLUDE_STUBBY=n

# DoH (DNS over HTTPS) - ОТКЛЮЧИТЬ (0.4MB + требует HTTPS)
CONFIG_FIRMWARE_INCLUDE_DOH=n

# Используем встроенный dnsmasq (легкий, уже есть в базе)
# Или настрой DNS вручную через resolv.conf


############################################################
## МЕДИА И ФАЙЛОВЫЕ СЕРВЕРЫ (ОТКЛЮЧИТЬ ВСЕ!)
############################################################

# UPnP медиасервер xUPNPd - ОТКЛЮЧИТЬ (0.3MB, не нужен на роутере)
CONFIG_FIRMWARE_INCLUDE_XUPNPD=n

# MiniDLNA - ОТКЛЮЧИТЬ! Очень тяжелый (1.6MB RAM)
# На 64MB роутере не останется памяти для VPN
CONFIG_FIRMWARE_INCLUDE_MINIDLNA=n

# Samba (SMB) сервер - ОТКЛЮЧИТЬ (1.5MB)
CONFIG_FIRMWARE_INCLUDE_SMBD=n
CONFIG_FIRMWARE_INCLUDE_SMBD_SYSLOG=n
CONFIG_FIRMWARE_INCLUDE_WINS=n
CONFIG_FIRMWARE_INCLUDE_TESTPARM=n


############################################################
## ТОРРЕНТЫ И ЗАГРУЗКИ (ОТКЛЮЧИТЬ ВСЕ!)
############################################################

# Transmission - ОТКЛЮЧИТЬ (1.5MB RAM + 0.8MB Web)
CONFIG_FIRMWARE_INCLUDE_TRANSMISSION=n
CONFIG_FIRMWARE_INCLUDE_TRANSMISSION_WEB_CONTROL=n

# Aria2 - ОТКЛЮЧИТЬ (3.5MB RAM!)
CONFIG_FIRMWARE_INCLUDE_ARIA=n
CONFIG_FIRMWARE_INCLUDE_ARIA_WEB_CONTROL=n


############################################################
## ПРОКСИ И АНОНИМНОСТЬ (ОТКЛЮЧИТЬ)
############################################################

# Tor - ОТКЛЮЧИТЬ (2.8MB RAM!)
CONFIG_FIRMWARE_INCLUDE_TOR=n
CONFIG_FIRMWARE_INCLUDE_TOR_GEOIP=n
CONFIG_FIRMWARE_INCLUDE_TOR_GEOIPV6=n
CONFIG_FIRMWARE_INCLUDE_OBFS4=n

# Privoxy - ОТКЛЮЧИТЬ (0.3MB, не нужен с WG)
CONFIG_FIRMWARE_INCLUDE_PRIVOXY=n


############################################################
## УТИЛИТЫ И ИНСТРУМЕНТЫ
############################################################

# tcpdump - ВКЛЮЧИТЬ (полезен для отладки сети, 0.6MB)
CONFIG_FIRMWARE_INCLUDE_TCPDUMP=y

# socat - ОТКЛЮЧИТЬ (0.3MB, редко нужен)
CONFIG_FIRMWARE_INCLUDE_SOCAT=n

# ndisc6/rdisc6 (IPv6 tools) - ОТКЛЮЧИТЬ (IPv6 выключен)
CONFIG_FIRMWARE_INCLUDE_NDISC6_RDISC6=n

# hdparm (настройка дисков) - не нужно (нет USB)
CONFIG_FIRMWARE_INCLUDE_HDPARM=n

# parted (разметка дисков) - не нужно
CONFIG_FIRMWARE_INCLUDE_PARTED=n

# Lua (скриптовый язык) - ВКЛЮЧИТЬ (нужен для некоторых скриптов)
CONFIG_FIRMWARE_INCLUDE_LUA=y

# iPerf3 (тест скорости) - ОТКЛЮЧИТЬ (0.13MB, можно установить потом)
CONFIG_FIRMWARE_INCLUDE_IPERF3=n

# KMS активация Windows - ОТКЛЮЧИТЬ
CONFIG_FIRMWARE_INCLUDE_VLMCSD=n


############################################################
## ПЕЧАТЬ И USB (НЕ НУЖНО)
############################################################

# LPR (печать) - ОТКЛЮЧИТЬ
CONFIG_FIRMWARE_INCLUDE_LPRD=n
# USB-over-Ethernet - ОТКЛЮЧИТЬ
CONFIG_FIRMWARE_INCLUDE_U2EC=n
# USB-over-IP - ОТКЛЮЧИТЬ
CONFIG_FIRMWARE_INCLUDE_USBIP=n


############################################################
## ФАЙЛОВЫЕ СИСТЕМЫ (ТОЛЬКО NTFS-3G ЕСЛИ НУЖНО)
############################################################

# NTFS-3G (через FUSE) - ОТКЛЮЧИТЬ (0.4MB, нет USB)
CONFIG_FIRMWARE_INCLUDE_NTFS_3G=n


############################################################
## ОПТИМИЗАЦИЯ РАЗМЕРА ПРОШИВКИ
############################################################

# Оптимизация компилятора для размера (вместо скорости)
# ВКЛЮЧИТЬ - прошивка меньше, но чуть медленнее
CONFIG_CC_OPTIMIZE_FOR_SIZE=y


############################################################
## ИТОГОВАЯ СТАТИСТИКА (примерно):
############################################################
# RAM использование базовой системы: ~25-30MB
# Остается свободно: ~30-35MB
# WireGuard: +~2-3MB на туннель
# NFQWS: +~0.5MB
# Итого свободно для работы: 20-25MB (достаточно для стабильности)
############################################################
