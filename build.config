############################################################
### Платформа и Продукт (Специально для ревизии v2 / R4AC)
############################################################
CONFIG_VENDOR=XIAOMI
CONFIG_PRODUCT=MT7628
CONFIG_FIRMWARE_PRODUCT_ID="MI-4A_100M_v2"

############################################################
### Ядро и Драйверы Wi-Fi
############################################################

### Драйвер 5ГГц.
### ВНИМАНИЕ: Для v2 ОБЯЗАТЕЛЬНО 4.1 (поддержка чипа MT7613).
### Значение 3.0 из старых конфигов не включит твой Wi-Fi.
CONFIG_FIRMWARE_WIFI5_DRIVER=4.1

### Драйвер 2.4ГГц. Стандартная версия для процессора MT7628.
CONFIG_FIRMWARE_WIFI2_DRIVER=4.0

### Сон процессора (понижение частоты).
### Выключено (#), чтобы не было лагов в играх и при обходе DPI.
#CONFIG_FIRMWARE_CPU_SLEEP=y

############################################################
### Сетевые функции и экономия памяти (ОЗУ 64МБ)
############################################################

### IPv6 — Выключено (n). Экономит около 3МБ оперативной памяти.
CONFIG_FIRMWARE_ENABLE_IPV6=y

### USB и файловые системы — Выключено (n), так как порта нет.
### Это освобождает место в прошивке и ОЗУ.
CONFIG_FIRMWARE_ENABLE_USB=n
CONFIG_FIRMWARE_ENABLE_FAT=n
CONFIG_FIRMWARE_ENABLE_EXFAT=n
CONFIG_FIRMWARE_ENABLE_EXT2=n
CONFIG_FIRMWARE_ENABLE_EXT3=n
CONFIG_FIRMWARE_ENABLE_EXT4=n
CONFIG_FIRMWARE_ENABLE_MSDOS=n
CONFIG_FIRMWARE_ENABLE_HFS=n
CONFIG_FIRMWARE_ENABLE_NTFS=n

############################################################
### Инструменты обхода блокировок и DNS
############################################################

### ZAPRET — Включаем (y). Основной сервис для YouTube/Discord.
CONFIG_FIRMWARE_INCLUDE_ZAPRET=y

### DNSCrypt — Включаем (y). Шифрует DNS-запросы, мало ест ОЗУ.
CONFIG_FIRMWARE_INCLUDE_DNSCRYPT=y

### DoT (Stubby) и DoH (Proxy) — Выключаем (n).
### Они дублируют DNSCrypt, но потребляют слишком много памяти.
CONFIG_FIRMWARE_INCLUDE_STUBBY=y
CONFIG_FIRMWARE_INCLUDE_DOH=n

### CURL — Включаем (y). Необходим для работы Zapret.
CONFIG_FIRMWARE_INCLUDE_CURL=y
CONFIG_FIRMWARE_INCLUDE_QUIC=n

### Прочие сервисы — Выключаем (n) для облегчения системы.
CONFIG_FIRMWARE_INCLUDE_PRIVOXY=n
CONFIG_FIRMWARE_INCLUDE_SHADOWSOCKS=y
CONFIG_FIRMWARE_INCLUDE_TOR=n

############################################################
### Оптимизация и стабильность (Критично для 64МБ)
############################################################

### ZRAM — Сжатие оперативной памяти. ОБЯЗАТЕЛЬНО ВКЛЮЧЕНО (y).
### Позволяет уместить больше процессов в 64МБ.
CONFIG_FIRMWARE_INCLUDE_ZRAM=n

### Автоматическая очистка кэша при нехватке памяти.
CONFIG_FIRMWARE_INCLUDE_DROP_CACHES=y

### Поддержка HTTPS для панели управления.
CONFIG_FIRMWARE_INCLUDE_HTTPS=y

### Стандартный Wi-Fi функционал (WPA2/3).
CONFIG_FIRMWARE_INCLUDE_WPAD=y

### Русский язык в интерфейсе (если билд поддерживает).
CONFIG_FIRMWARE_INCLUDE_LANG_RU=y
